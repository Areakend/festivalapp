# ── Supabase (client-safe: the anon key is meant to be public, RLS protects data) ──
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Spotify ──
# ONLY the client ID lives in the app (used for the PKCE OAuth flow).
# The client SECRET must NEVER be here: it belongs in Supabase Edge Function
# secrets (`supabase secrets set SPOTIFY_CLIENT_SECRET=...`).
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=your-spotify-client-id

# ── Deezer ──
# ONLY the app ID lives in the app. The app SECRET must NEVER be here: it
# belongs in Supabase Edge Function secrets:
#   supabase secrets set DEEZER_APP_ID=... DEEZER_APP_SECRET=...
# Register the app at https://developers.deezer.com/myapps — the redirect
# URI to whitelist there is festiq://deezer/callback.
EXPO_PUBLIC_DEEZER_APP_ID=your-deezer-app-id
