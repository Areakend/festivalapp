{
  "expo": {
    "name": "Mainstage",
    "slug": "festiq",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "festiq",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#0B0B14",
    "icon": "./assets/icon.png",
    "ios": {
      "bundleIdentifier": "com.areakend.festiq",
      "supportsTablet": false
    },
    "android": {
      "package": "com.areakend.festiq",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B0B14"
      },
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "expo-web-browser",
      "expo-updates"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1ec3a118-4625-478d-9388-284f1d435b92"
      }
    },
    "owner": "areakend",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1ec3a118-4625-478d-9388-284f1d435b92"
    }
  }
}
