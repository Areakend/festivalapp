{
  "expo": {
    "name": "Mainstage",
    "slug": "festiq",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "festiq",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#0B0B14",
    "icon": "./assets/icon.png",
    "ios": {
      "bundleIdentifier": "com.areakend.festiq",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "2"
    },
    "android": {
      "package": "com.areakend.festiq",
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B0B14"
      },
      "edgeToEdgeEnabled": true,
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "expo-web-browser",
      "expo-updates",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you use one as a share card background."
        }
      ],
      [
        "expo-media-library",
        {
          "savePhotosPermission": "The app saves your generated share cards to your photos.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1ec3a118-4625-478d-9388-284f1d435b92"
      }
    },
    "owner": "areakend",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1ec3a118-4625-478d-9388-284f1d435b92"
    }
  }
}
